#!/usr/bin/env bash
set -euo pipefail

REPO_METADATA_ENV_FILE="${REPO_METADATA_ENV_FILE:-/etc/default/ai-appliance-repo}"

if [[ ! -f "$REPO_METADATA_ENV_FILE" ]]; then
  echo "Missing repository metadata file: $REPO_METADATA_ENV_FILE" >&2
  exit 1
fi

# shellcheck disable=SC1090
set -a
source "$REPO_METADATA_ENV_FILE"
set +a

GIT_HOST="${GIT_HOST:-github.com}"
GIT_BRANCH="${GIT_BRANCH:-main}"
FLUX_BOOTSTRAP_MODE="${FLUX_BOOTSTRAP_MODE:-github}"
MAGICSTICK_PUBLIC_REPO="${MAGICSTICK_PUBLIC_REPO:-https://github.com/QualityMinds/AIppliance-Magic-Stick.git}"
MAGICSTICK_PUBLIC_REF="${MAGICSTICK_PUBLIC_REF:-main}"
MAGICSTICK_PUBLIC_REF_KIND="${MAGICSTICK_PUBLIC_REF_KIND:-branch}"
MAGICSTICK_PUBLIC_CHECKOUT="${MAGICSTICK_PUBLIC_CHECKOUT:-/opt/ai-appliance/magicstick}"
AI_APPLIANCE_PRIVATE_CHECKOUT="${AI_APPLIANCE_PRIVATE_CHECKOUT:-/opt/ai-appliance/deployment}"
ANSIBLE_INVENTORY_PATH="${ANSIBLE_INVENTORY_PATH:-infra-host/inventory/localhost.yml}"
ANSIBLE_PLAYBOOK_PATH="${ANSIBLE_PLAYBOOK_PATH:-infra-host/playbooks/local.yml}"
FLUX_CLUSTER_PATH="${FLUX_CLUSTER_PATH:-deployments/CHANGEME_DEPLOYMENT/infra-cluster/flux-bootstrap}"
FLUX_PUBLIC_SYNC_PATH="${FLUX_PUBLIC_SYNC_PATH:-infra-cluster/profiles/single-node/flux-bootstrap}"
AI_APPLIANCE_DOMAIN="${AI_APPLIANCE_DOMAIN:-example.local}"
AI_APPLIANCE_DASHBOARD_HOST="${AI_APPLIANCE_DASHBOARD_HOST:-dashboard.example.local}"
AI_APPLIANCE_DASHBOARD_MDNS_NAME="${AI_APPLIANCE_DASHBOARD_MDNS_NAME:-ai-appliance}"
AI_APPLIANCE_ANYTHING_LLM_STORAGE="${AI_APPLIANCE_ANYTHING_LLM_STORAGE:-1Gi}"
AI_APPLIANCE_QDRANT_STORAGE="${AI_APPLIANCE_QDRANT_STORAGE:-1Gi}"
AI_APPLIANCE_LITELLM_POSTGRES_STORAGE="${AI_APPLIANCE_LITELLM_POSTGRES_STORAGE:-1Gi}"
AI_APPLIANCE_LOKI_STORAGE="${AI_APPLIANCE_LOKI_STORAGE:-1Gi}"
AI_APPLIANCE_ALERTMANAGER_STORAGE="${AI_APPLIANCE_ALERTMANAGER_STORAGE:-1Gi}"
AI_APPLIANCE_PROMETHEUS_STORAGE="${AI_APPLIANCE_PROMETHEUS_STORAGE:-1Gi}"

require_var() {
  local name="$1"
  local value="${!name:-}"

  if [[ -z "$value" || "$value" == CHANGEME* || "$value" == REPLACE_WITH* ]]; then
    echo "Missing required metadata variable: $name" >&2
    exit 1
  fi
}

case "$FLUX_BOOTSTRAP_MODE" in
  github | readonly-public) ;;
  *)
    echo "Unsupported FLUX_BOOTSTRAP_MODE: $FLUX_BOOTSTRAP_MODE" >&2
    exit 1
    ;;
esac

case "$MAGICSTICK_PUBLIC_REF_KIND" in
  branch | tag | semver | commit) ;;
  *)
    echo "Unsupported MAGICSTICK_PUBLIC_REF_KIND: $MAGICSTICK_PUBLIC_REF_KIND" >&2
    exit 1
    ;;
esac

require_var MAGICSTICK_PUBLIC_REPO
require_var MAGICSTICK_PUBLIC_REF
require_var FLUX_PUBLIC_SYNC_PATH

if [[ "$FLUX_BOOTSTRAP_MODE" == "github" ]]; then
  require_var GIT_OWNER
  require_var GIT_REPO
  require_var GIT_BRANCH
  require_var FLUX_CLUSTER_PATH
fi

PRIVATE_REPO_URL=""
if [[ "$FLUX_BOOTSTRAP_MODE" == "github" ]]; then
  PRIVATE_REPO_URL="https://${GIT_HOST}/${GIT_OWNER}/${GIT_REPO}.git"
fi
ASKPASS_FILE=""

cleanup() {
  if [[ -n "$ASKPASS_FILE" && -f "$ASKPASS_FILE" ]]; then
    rm -f "$ASKPASS_FILE"
  fi
}
trap cleanup EXIT

token_is_runtime_value() {
  local token="${FLUX_GITHUB_TOKEN:-}"
  [[ -n "$token" && "$token" != CHANGEME* && "$token" != REPLACE_WITH* && "$token" != "<github-pat>" ]]
}

if [[ "$FLUX_BOOTSTRAP_MODE" == "github" ]] && token_is_runtime_value; then
  ASKPASS_FILE="$(mktemp)"
  chmod 0700 "$ASKPASS_FILE"
  cat >"$ASKPASS_FILE" <<'EOF'
#!/usr/bin/env bash
case "$1" in
  *Username*) printf '%s\n' "x-access-token" ;;
  *Password*) printf '%s\n' "${FLUX_GITHUB_TOKEN}" ;;
  *) printf '%s\n' "${FLUX_GITHUB_TOKEN}" ;;
esac
EOF
  export GIT_ASKPASS="$ASKPASS_FILE"
  export GIT_TERMINAL_PROMPT=0
fi

sync_repo() {
  local repo_url="$1"
  local ref="$2"
  local checkout_dir="$3"

  mkdir -p "$(dirname "$checkout_dir")"

  if [[ -d "$checkout_dir/.git" ]]; then
    git -C "$checkout_dir" remote set-url origin "$repo_url"
  else
    rm -rf "$checkout_dir"
    git clone --no-checkout "$repo_url" "$checkout_dir"
  fi

  git -C "$checkout_dir" fetch --tags --prune origin

  if git -C "$checkout_dir" show-ref --verify --quiet "refs/remotes/origin/${ref}"; then
    git -C "$checkout_dir" checkout --force -B "$ref" "origin/${ref}"
  else
    git -C "$checkout_dir" checkout --force --detach "$ref"
  fi
}

resolve_checkout_path() {
  local base="$1"
  local path="$2"

  case "$path" in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "$base" "$path" ;;
  esac
}

resolve_inventory_path() {
  local path="$1"
  local candidate=""
  local inventory_file=""

  case "$path" in
    /*)
      if [[ -e "$path" ]]; then
        printf '%s\n' "$path"
        return
      fi
      ;;
    *)
      candidate="$(resolve_checkout_path "$AI_APPLIANCE_PRIVATE_CHECKOUT" "$path")"
      if [[ -e "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return
      fi

      candidate="$(resolve_checkout_path "$MAGICSTICK_PUBLIC_CHECKOUT" "$path")"
      if [[ -e "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return
      fi

      if [[ "$path" == deployments/*/infra-host/inventory/* ]]; then
        inventory_file="${path#*infra-host/inventory/}"
        candidate="$MAGICSTICK_PUBLIC_CHECKOUT/infra-host/inventory/$inventory_file"
        if [[ -e "$candidate" ]]; then
          printf '%s\n' "$candidate"
          return
        fi
      fi
      ;;
  esac

  echo "Missing Ansible inventory path: $path" >&2
  echo "Checked private checkout, public checkout, and legacy public inventory fallback." >&2
  exit 1
}

sync_repo "$MAGICSTICK_PUBLIC_REPO" "$MAGICSTICK_PUBLIC_REF" "$MAGICSTICK_PUBLIC_CHECKOUT"

if [[ "$FLUX_BOOTSTRAP_MODE" == "github" ]]; then
  sync_repo "$PRIVATE_REPO_URL" "$GIT_BRANCH" "$AI_APPLIANCE_PRIVATE_CHECKOUT"
fi

INVENTORY_PATH="$(resolve_inventory_path "$ANSIBLE_INVENTORY_PATH")"
PLAYBOOK_PATH="$(resolve_checkout_path "$MAGICSTICK_PUBLIC_CHECKOUT" "$ANSIBLE_PLAYBOOK_PATH")"
PUBLIC_ROLES_PATH="$MAGICSTICK_PUBLIC_CHECKOUT/infra-host/roles"

export ANSIBLE_ROLES_PATH="${PUBLIC_ROLES_PATH}${ANSIBLE_ROLES_PATH:+:${ANSIBLE_ROLES_PATH}}"

ansible_args=(
  -i "$INVENTORY_PATH"
  -e "flux_bootstrap_mode=$FLUX_BOOTSTRAP_MODE"
  -e "magicstick_public_repo=$MAGICSTICK_PUBLIC_REPO"
  -e "magicstick_public_ref=$MAGICSTICK_PUBLIC_REF"
  -e "magicstick_public_ref_kind=$MAGICSTICK_PUBLIC_REF_KIND"
  -e "flux_public_sync_path=$FLUX_PUBLIC_SYNC_PATH"
  -e "ai_appliance_domain=$AI_APPLIANCE_DOMAIN"
  -e "ai_appliance_dashboard_host=$AI_APPLIANCE_DASHBOARD_HOST"
  -e "ai_appliance_dashboard_mdns_name=$AI_APPLIANCE_DASHBOARD_MDNS_NAME"
  -e "ai_appliance_anything_llm_storage=$AI_APPLIANCE_ANYTHING_LLM_STORAGE"
  -e "ai_appliance_qdrant_storage=$AI_APPLIANCE_QDRANT_STORAGE"
  -e "ai_appliance_litellm_postgres_storage=$AI_APPLIANCE_LITELLM_POSTGRES_STORAGE"
  -e "ai_appliance_loki_storage=$AI_APPLIANCE_LOKI_STORAGE"
  -e "ai_appliance_alertmanager_storage=$AI_APPLIANCE_ALERTMANAGER_STORAGE"
  -e "ai_appliance_prometheus_storage=$AI_APPLIANCE_PROMETHEUS_STORAGE"
  -e "repo_metadata_env_file=$REPO_METADATA_ENV_FILE"
  "$PLAYBOOK_PATH"
)

if [[ "$FLUX_BOOTSTRAP_MODE" == "github" ]]; then
  ansible_args=(
    -i "$INVENTORY_PATH"
    -e "monorepo_url=$PRIVATE_REPO_URL"
    -e "flux_github_owner=$GIT_OWNER"
    -e "flux_github_repo=$GIT_REPO"
    -e "flux_github_branch=$GIT_BRANCH"
    -e "flux_cluster_path=$FLUX_CLUSTER_PATH"
    -e "flux_github_token=${FLUX_GITHUB_TOKEN:-}"
    -e "flux_bootstrap_mode=$FLUX_BOOTSTRAP_MODE"
    -e "magicstick_public_repo=$MAGICSTICK_PUBLIC_REPO"
    -e "magicstick_public_ref=$MAGICSTICK_PUBLIC_REF"
    -e "magicstick_public_ref_kind=$MAGICSTICK_PUBLIC_REF_KIND"
    -e "flux_public_sync_path=$FLUX_PUBLIC_SYNC_PATH"
    -e "repo_metadata_env_file=$REPO_METADATA_ENV_FILE"
    "$PLAYBOOK_PATH"
  )
fi

exec ansible-playbook "${ansible_args[@]}"
