#cloud-config
autoinstall:
  version: 1

  interactive-sections:
    - storage
    - identity
    - ssh
    - keyboard
    - locale

  packages:
    - git
    - ansible
    - curl
    - ca-certificates

  user-data:
    manage_etc_hosts: true

    write_files:
      - path: /etc/default/ai-appliance-repo
        owner: root:root
        permissions: "0600"
        content: |
          # Zentrale (nicht-sensitive) Git-Metadaten fuer Bootstrap, Host-Converge und Flux.
          GIT_HOST=github.com
          GIT_OWNER=REPLACE_WITH_GIT_OWNER
          GIT_REPO=REPLACE_WITH_GIT_REPO
          GIT_BRANCH=REPLACE_WITH_GIT_BRANCH
          MAGICSTICK_PUBLIC_REPO=https://github.com/QualityMinds/AIppliance-Magic-Stick.git
          MAGICSTICK_PUBLIC_REF=v0.1.7
          MAGICSTICK_PUBLIC_CHECKOUT=/opt/ai-appliance/magicstick
          AI_APPLIANCE_PRIVATE_CHECKOUT=/opt/ai-appliance/deployment
          FLUX_CLUSTER_PATH=deployments/CHANGEME_DEPLOYMENT/infra-cluster/flux-bootstrap
          ANSIBLE_INVENTORY_PATH=infra-host/inventory/localhost.yml
          ANSIBLE_PLAYBOOK_PATH=infra-host/playbooks/local.yml
          FLUX_GITHUB_TOKEN=REPLACE_WITH_FLUX_GITHUB_TOKEN

    runcmd:
      - >
        /bin/bash -lc '. /etc/default/ai-appliance-repo &&
        MAGICSTICK_PUBLIC_REPO="${MAGICSTICK_PUBLIC_REPO:-https://github.com/QualityMinds/AIppliance-Magic-Stick.git}" &&
        MAGICSTICK_PUBLIC_REF="${MAGICSTICK_PUBLIC_REF:-v0.1.7}" &&
        MAGICSTICK_PUBLIC_CHECKOUT="${MAGICSTICK_PUBLIC_CHECKOUT:-/opt/ai-appliance/magicstick}" &&
        mkdir -p "$(dirname "$MAGICSTICK_PUBLIC_CHECKOUT")" &&
        if [ -d "$MAGICSTICK_PUBLIC_CHECKOUT/.git" ]; then
          git -C "$MAGICSTICK_PUBLIC_CHECKOUT" fetch --tags --prune origin;
        else
          rm -rf "$MAGICSTICK_PUBLIC_CHECKOUT" &&
          git clone --no-checkout "$MAGICSTICK_PUBLIC_REPO" "$MAGICSTICK_PUBLIC_CHECKOUT";
        fi &&
        git -C "$MAGICSTICK_PUBLIC_CHECKOUT" fetch --tags --prune origin &&
        git -C "$MAGICSTICK_PUBLIC_CHECKOUT" checkout --force --detach "$MAGICSTICK_PUBLIC_REF" &&
        bash "$MAGICSTICK_PUBLIC_CHECKOUT/infra-host/roles/ansible-pull-timer/files/ai-appliance-converge"'
